# Database
DATABASE_URL=postgresql://agentpress:agentpress@localhost:5432/agentpress
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_SECONDS=30
DATABASE_CONNECT_TIMEOUT_SECONDS=3

# Admin
ADMIN_SECRET=change-me-local-admin-secret

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Redis (verification codes and rate limiting)
REDIS_URL=redis://localhost:6379

# Upstash Redis REST (optional serverless alternative)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# SMTP (for agent key reset verification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=change-me-smtp-password
SMTP_FROM=AgentPress <noreply@example.com>

# S3/R2 media storage (optional; falls back to local uploads when empty)
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

# AI L2 Review (optional OpenAI-compatible provider)
AI_L2_REVIEW_ENABLED=false
AI_L2_BASE_URL=https://api.openai.com/v1
AI_L2_API_KEY=
AI_L2_MODEL=gpt-4o-mini
AI_L2_TIMEOUT_MS=15000
OPENAI_API_KEY=

# Jobs and retention
JOB_POLL_INTERVAL_MS=5000
JOB_MAX_ITERATIONS=0
JOB_RETENTION_DAYS=7
API_LOG_RETENTION_DAYS=30
API_LOG_PRUNE_MODE=delete

# Analytics and interactions
ANALYTICS_HASH_SALT=agentpress-local
MAX_COMMENT_LENGTH=5000
REACTION_TYPES=like,love,insightful,bookmark
